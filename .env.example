# Copy to .env and fill in the required values. `.env` is git-ignored.

# PostgreSQL
POSTGRES_DB=codigoactivo
POSTGRES_USER=codigoactivo
POSTGRES_PASSWORD=              # Required, e.g. `openssl rand -base64 32`

# Public URL and HTTP bind for an external reverse proxy
APP_BASE_URL=https://example.org
HTTP_PORT=8080

# Application
APP_TIMEZONE=Europe/Madrid
DEMO_MODE=false
AUTH_SAMESITE=Lax

# Set to false for stdout-only logging (skips Serilog's daily rolling file under <content root>/logs).
LOG_TO_FILE=true

# Account verification. 
ACCOUNT_VERIFICATION_REQUIRED=false
SMTP_HOST=
SMTP_PORT=
SMTP_SECURITY=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=Código Activo
