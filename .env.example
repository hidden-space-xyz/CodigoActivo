# Copy to .env and fill in the required values. `.env` is git-ignored.

# PostgreSQL
POSTGRES_DB=codigoactivo
POSTGRES_USER=codigoactivo
POSTGRES_PASSWORD=              # required, e.g. `openssl rand -base64 32`

# Public domain — must resolve publicly and reach ports 80/443 for Let's Encrypt.
SERVER_NAME=example.org
APP_BASE_URL=https://example.org
HTTP_PORT=80
HTTPS_PORT=443

# Let's Encrypt (issues ECDSA certificates)
LETSENCRYPT_EMAIL=             # required, receives expiry notices
LETSENCRYPT_STAGING=0          # 1 = staging endpoint for testing (avoids rate limits)

# Application
APP_TIMEZONE=Europe/Madrid
DEMO_MODE=false
AUTH_SAMESITE=Lax

# Account verification. When true, requires SMTP_HOST and SMTP_FROM_ADDRESS.
ACCOUNT_VERIFICATION_REQUIRED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURITY=StartTls
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=Código Activo

# Leave empty (same-origin /api). A split-origin API also needs CSP/CORS changes.
VITE_API_BASE_URL=
