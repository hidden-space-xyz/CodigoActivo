{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Serilog.AspNetCore.RequestLoggingMiddleware": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "DemoMode": true,
  "App": {
    "TimeZone": "Europe/Madrid",
    "BaseUrl": "http://localhost:5173"
  },
  "ConnectionStrings": {
    "Default": ""
  },
  "FileStorage": {
    "RootPath": "files",
    "MaxSizeBytes": 10485760
  },
  "Auth": {
    "CookieName": "CodigoActivo.Session",
    "SameSite": "Lax",
    "ExpireHours": 8
  },
  "AccountVerification": {
    "Required": true,
    "OtpLifetimeMinutes": 15,
    "ResendCooldownSeconds": 60
  },
  "Smtp": {
    "Host": "",
    "Port": 587,
    "Security": "StartTls",
    "FromAddress": "",
    "FromName": "Código Activo"
  }
}
