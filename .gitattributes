# Keep container/shell assets LF-terminated regardless of the checkout OS,
# otherwise CRLF breaks shebangs and nginx/entrypoint scripts inside the images.
*.sh            text eol=lf
*.conf          text eol=lf
*.template      text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
Dockerfile      text eol=lf
.dockerignore   text eol=lf
.env.example    text eol=lf
